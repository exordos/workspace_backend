    workspace_backend_nginx:
      project_id: "12345678-c625-4fee-81d5-f691897b8142"
      path: /etc/nginx/sites-available/workspace.conf
      target:
        kind: node
        node: $core.compute.nodes.$workspace_backend:uuid
      on_change:
        kind: shell
        command: /usr/local/bin/workspace-nginx-reload
      body:
        kind: text
        content: |
          upstream workspace_core_api {
              include /etc/nginx/workspace.d/core-upstream.conf;
          }

          server {
              listen 80;
              server_name _;
              client_max_body_size 50m;

              location /api/core/ {
                  proxy_pass http://workspace_core_api/api/core/;
                  proxy_set_header Host $http_host;
                  proxy_set_header X-Real-IP $remote_addr;
                  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                  proxy_set_header X-Forwarded-Proto https;
              }

              location = /api/workspace/v1/events/ws {
                  proxy_pass http://127.0.0.1:21082/v1/events/ws;
                  proxy_set_header Host $http_host;
                  proxy_set_header X-Real-IP $remote_addr;
                  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                  proxy_set_header X-Forwarded-Proto https;

                  proxy_http_version 1.1;
                  proxy_set_header Upgrade $http_upgrade;
                  proxy_set_header Connection "upgrade";
                  proxy_read_timeout 3600s;
                  proxy_send_timeout 3600s;
              }

              location /api/workspace/v1/messenger/ {
                  proxy_pass http://127.0.0.1:21081/v1/;
                  proxy_set_header Host $http_host;
                  proxy_set_header X-Real-IP $remote_addr;
                  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                  proxy_set_header X-Forwarded-Proto https;
              }

              location /api/workspace/ {
                  proxy_pass http://127.0.0.1:21084/;
                  proxy_set_header Host $http_host;
                  proxy_set_header X-Real-IP $remote_addr;
                  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
                  proxy_set_header X-Forwarded-Proto https;
              }

              location = /logo-512x512.png {
                  alias /opt/workspace-ui/packages/web/dist/pwa-512x512.png;
              }

              location / {
                  root /opt/workspace-ui/packages/web/dist;
                  try_files $uri $uri/ /index.html;
              }
          }

    workspace_backend_nginx_core_upstream:
      project_id: "12345678-c625-4fee-81d5-f691897b8142"
      path: /etc/nginx/workspace.d/core-upstream.conf
      target:
        kind: node
        node: $core.compute.nodes.$workspace_backend:uuid
      on_change:
        kind: shell
        command: /usr/local/bin/workspace-nginx-reload
      body:
        kind: text
        content: |
          f"server {$workspace.imports.$var_core_ip_address:value}:80;"

